# ============================================================
# FUJI-SAKE-PREMIUM 環境変数テンプレート
# ------------------------------------------------------------
# このファイルをコピーして `.env.local` を作成してください:
#   cp .env.example .env.local
#
# `.env*` は .gitignore 済みのため、実値は GitHub に push されません。
# ============================================================

# --- GitHub / Git 認証 ---
GITHUB_TOKEN=
GITHUB_USERNAME=

# --- Vercel ---
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_ORG_ID=

# --- データベース / API ---
DATABASE_URL=
API_KEY=
API_SECRET=

# --- 認証系 (Better Auth) ---
# ローカル開発では実値を .dev.vars に置く（wrangler / OpenNext が読み込む）。
# 本番は `wrangler secret put <NAME>` で投入する。
# 32バイトのシークレット: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# メール認証の送信に使う（未設定ならローカルはコンソールにリンク出力）
RESEND_API_KEY=
RESEND_FROM=FUJISAN SAKE <onboarding@resend.dev>
# Google ログイン（任意。設定するとログイン画面に Google ボタンが出る）
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- その他のパスワード・機密情報 ---
ADMIN_PASSWORD=
SMTP_PASSWORD=
