# ============================================================
# Command Center — Google API 認証情報
# ------------------------------------------------------------
# 手順:
# 1. https://console.cloud.google.com/ でプロジェクト作成
# 2. APIs & Services → Credentials → OAuth 2.0 Client ID (Desktop app)
# 3. 以下の値を .env.local にコピー（.env.local は .gitignore 済み）
# ============================================================

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:53682/callback

# --- 有効にするスコープ (参考) ---
# https://www.googleapis.com/auth/gmail.readonly
# https://www.googleapis.com/auth/gmail.send
# https://www.googleapis.com/auth/calendar
